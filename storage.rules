rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // /publications/{pubId}/{filename}
    //
    // Photos uploaded for user-submitted property listings.
    // - read: public. Approved listings are shown in the search to all
    //         visitors; pending ones are only linked from the owner's
    //         "Mis publicaciones" view but URLs are unguessable, so a
    //         public read is acceptable for an MVP.
    // - write: any authenticated user. We rely on Firestore rules to
    //         enforce that the matching publication doc has the right
    //         userId. Tighter binding (e.g. checking the doc from
    //         Storage rules) requires custom claims or a Cloud Function
    //         and can be added in Phase 3.
    match /publications/{pubId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
