rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Hardcoded admin allowlist. Edit this list to grant or revoke
    // moderation rights. Phase 3 keeps the auth model simple; later
    // phases may move this to custom claims or an /admins collection.
    //
    // The email from the auth token is lower-cased before the lookup so
    // an admin who happened to register with mixed case (e.g. "Webmaster
    // @recosac.com") still matches the allowlist. The client-side
    // _isAdmin() helper already lower-cases; this keeps the two checks
    // in sync so the UI and the rule agree on who is admin.
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email != null
             && request.auth.token.email.lower() in [
               'webmaster@recosac.com',
               'sebastiand@recosac.com'
             ];
    }

    // /users/{uid}
    //
    // Each authenticated user can read and write only their own profile
    // document. The document holds favorites, keyHistory, keysLeft and
    // basic profile metadata (email, displayName, createdAt).
    //
    // keysLeft and keyHistory are the ledger for the paid-key economy.
    // They MUST NOT be writable from the client — a browser can open
    // DevTools and run `db.collection('users').doc(uid).update({keysLeft:
    // 9999})`, bypassing any UI purchase flow. Both fields are managed
    // server-side: a Cloud Function receives the payment webhook to add
    // keys, and another callable Cloud Function decrements keys on
    // unlock/publish. Those functions use the admin SDK and bypass these
    // rules, so users can still spend/earn keys — just not by writing
    // directly from the browser.
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Create and update use an explicit field whitelist rather than
      // blocklisting keysLeft/keyHistory. Rationale: the old blocklist
      // let the client set arbitrary fields the code may read later
      // (e.g. `isAdmin`, `role`, `premium`), so any future author could
      // wire a privilege check to a user-controlled field without
      // noticing. It also allowed unbounded doc bloat. Any new
      // legitimate field added to the schema must also be added here.
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.keys().hasOnly(['email', 'displayName', 'createdAt', 'favorites', 'keysLeft', 'keyHistory'])
                    && (!('keysLeft' in request.resource.data) || request.resource.data.keysLeft == 0)
                    && (!('keyHistory' in request.resource.data) || request.resource.data.keyHistory.size() == 0);
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites', 'email', 'displayName']);
      allow delete: if false; // never allow self-delete from client
    }

    // /publications/{pubId}
    //
    // User-submitted property listings that go through moderation.
    // - read: the owner can read their own publications regardless of
    //         status; anyone (auth or not) can read approved listings,
    //         because Phase 4 will surface them in the public search.
    // - create: any authenticated user can create, but the new doc must
    //           have userId == request.auth.uid and status == 'pending'.
    //           This prevents users from forging ownership or skipping
    //           moderation.
    // - update: the owner may update their own listing only while it
    //           is still pending, and may not change status, userId or
    //           createdAt. Admin moderation will be done server-side or
    //           with a separate admin claim in Phase 3.
    // - delete: only the owner may delete their listing.
    match /publications/{pubId} {
      // Read: approved listings are public; the owner sees their own
      // regardless of status; admins see everything (so the moderation
      // panel can list pending and rejected docs).
      allow read: if resource.data.status == 'approved'
                  || (request.auth != null && resource.data.userId == request.auth.uid)
                  || isAdmin();
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending';
      // Update: owner can edit while pending (without flipping status/
      // userId/createdAt). Admin can change any field — typically just
      // status and an optional rejectionReason / moderatedAt.
      allow update: if (request.auth != null
                       && resource.data.userId == request.auth.uid
                       && resource.data.status == 'pending'
                       && request.resource.data.userId == resource.data.userId
                       && request.resource.data.status == resource.data.status
                       && request.resource.data.createdAt == resource.data.createdAt)
                    || isAdmin();
      // Delete: owner or admin (admin can remove spam outright).
      allow delete: if (request.auth != null && resource.data.userId == request.auth.uid)
                    || isAdmin();
    }

    // /contactRequests/{reqId}
    //
    // Requests generated when a user clicks "Contactar arrendador",
    // "Contactar vendedor" or "Solicitar asesoría" on a property card.
    // The request captures who is asking, about which property, and any
    // message they left. Reco team (admins) reads these; the owner of a
    // user-published listing can also read requests targeted at them.
    // The publication owner can additionally mark them as 'handled'.
    match /contactRequests/{reqId} {
      allow read: if request.auth != null
                  && (resource.data.fromUserId == request.auth.uid
                      || resource.data.publicationOwnerId == request.auth.uid
                      || isAdmin());
      // The doc ID must be `${fromUserId}_${propertyId}_${kind}`. Since
      // `allow create` only fires when the doc does not already exist,
      // this forces one contactRequest per (sender, property, modality).
      // A second attempt reads as an update, which the sender is not
      // permitted to perform (see `allow update` below), so it fails
      // with permission-denied.
      allow create: if request.auth != null
                    && request.resource.data.fromUserId == request.auth.uid
                    && request.resource.data.status == 'new'
                    && request.resource.data.propertyId is string
                    && request.resource.data.kind in ['arrendador','vendedor','asesor_reco']
                    && reqId == request.auth.uid + '_' + request.resource.data.propertyId + '_' + request.resource.data.kind;
      // Admins can update anything; the publication owner can only flip
      // `status` (e.g. 'new' → 'handled'). The prior version of this rule
      // let the owner rewrite fromName, fromEmail, message and other
      // requester-owned fields as long as three immutable IDs stayed the
      // same, which meant a malicious owner could tamper with the record
      // Reco reads for moderation. Restricting affectedKeys to ['status']
      // makes every other field owner-immutable and drops the redundant
      // per-field comparisons.
      allow update: if isAdmin()
                    || (request.auth != null
                        && resource.data.publicationOwnerId == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
      allow delete: if isAdmin();
    }

    // /mail/{docId}
    //
    // Outbox for the "Trigger Email from Firestore" Firebase extension.
    // The extension reads docs from this collection and dispatches the
    // emails over SMTP (Resend in our setup).
    //
    // - read: always denied from clients; the extension writes
    //         delivery.state / delivery.error via the Admin SDK.
    // - create: admins can queue any email (moderation notices); other
    //           authenticated users can also queue mail, but only if
    //           the doc records fromUserId == their uid — this lets the
    //           "contact owner" flow email the publication owner while
    //           keeping a paper trail per sender in case of abuse.
    match /mail/{docId} {
      allow read: if false;
      allow create: if isAdmin()
                    || (request.auth != null
                        && request.resource.data.fromUserId == request.auth.uid
                        && request.resource.data.to is string
                        && request.resource.data.message is map);
      allow update, delete: if false;
    }

    // Default deny for any other path
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
